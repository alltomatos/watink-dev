# ─── Watink Dev Environment ───
# Copy this file to .env and fill in real values before running:
#   cp .env.example .env

# ─── Domains ───
APP_DOMAIN=app.localhost
API_DOMAIN=api.localhost

# ─── Database ───
DB_PASS=watink_secret_pass
POSTGRES_USER=postgres
POSTGRES_PASSWORD=watink_secret_pass
POSTGRES_DB=watink

# ─── Auth ───
JWT_SECRET=dev_jwt_secret_change_in_prod
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_prod

# ─── Docs ───
# DOCS_PUBLIC=true → libera /api/v1/docs sem token (apenas dev; nunca em prod)
DOCS_PUBLIC=true

# ─── Marketplace Hub ───
HUB_PORT=8090
APP_BASE_URL=http://localhost:8090
ADMIN_TOKEN=dev_admin_token
ADMIN_USER=admin
ADMIN_PASSWORD=dev_admin_pass
DOWNLOAD_SIGNING_SECRET=dev_signing_secret

# ─── GitHub (for plugin catalog auto-sync) ───
GITHUB_TOKEN=

# ─── Plugin Manager (licenças + catálogo + instância) ───
# Base URL do plugin-manager local que o business consulta (nunca o Hub direto,
# ADR 0024). No Docker/Compose use http://plugin-manager:8081.
PLUGIN_MANAGER_URL=http://localhost:8081
# TTL (segundos) do cache em memória do status de licença no business.
PLUGIN_LICENSE_CACHE_TTL_SECONDS=60
