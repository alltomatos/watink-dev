# ─── Watink Production Environment ───
# Usado pelo docker-compose.yml (distribuição via Docker Hub, imagens
# ronaldodavi/watink-*). Copie e preencha com segredos REAIS antes de subir:
#   cp .env.production.example .env
#
# Gere cada segredo com: openssl rand -hex 32
# NUNCA reuse os valores de exemplo do .env.example (esse é só para
# docker-compose.dev.yml / desenvolvimento local).

# ─── Imagem ───
# Tag publicada por .github/workflows/publish-dockerhub.yml:
#   latest  → último push em main (estável)
#   develop → último push em develop (homologação)
#   sha-<hash> → build de um commit específico
IMAGE_TAG=latest

# ─── Porta pública (host) ───
PORT=80

# ─── Database ───
DB_PASS=

# ─── RabbitMQ ───
RABBITMQ_USER=watink
RABBITMQ_PASS=

# ─── Auth ───
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Criptografia at-rest (senhas de proxy) ───
PROXY_ENC_KEY=

# ─── Token interno (business ↔ serviços internos) ───
INTERNAL_TOKEN=
