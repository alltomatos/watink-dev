{
  "name": "watinkdev",
  "version": "1.0.0",
  "description": "Watink OpenCore - Plataforma open-source de atendimento e automacao no WhatsApp",
  "main": "ecosystem.config.js",
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "playwright": "^1.58.2",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:ui": "cd e2e && npx playwright test --ui",
    "test:e2e:api": "cd e2e && npx playwright test tests/tickets tests/admin tests/multitenancy --project=chromium",
    "windows:check": "powershell -ExecutionPolicy Bypass -File ./scripts/windows-business-check.ps1",
    "windows:business": "start.bat",
    "windows:business:check": "npm run windows:check ; npm run windows:business",
    "windows:opencore": "start.bat",
    "windows:business:server": "start-business-windows.bat",
    "windows:stack": "npm run windows:check ; npm run windows:business:server",
    "linux:docker:business": "bash ./scripts/linux-docker-business.sh up",
    "linux:docker:business:down": "bash ./scripts/linux-docker-business.sh down",
    "linux:docker:business:rebuild": "bash ./scripts/linux-docker-business.sh rebuild",
    "linux:docker:dev": "docker compose -f docker-compose.dev.yml up",
    "linux:docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "linux:docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*.{js,jsx,ts,tsx}": [
      "bash scripts/lint-frontend.sh"
    ],
    "business/**/*.go": [
      "gofmt -w"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alltomatos/watinkdev.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alltomatos/watinkdev/issues"
  },
  "homepage": "https://github.com/alltomatos/watinkdev#readme"
}
